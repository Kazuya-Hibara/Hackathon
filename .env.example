# TiDB Cloud Zero (get from: curl -X POST https://zero.tidbapi.com/v1beta1/instances)
TIDB_CONNECTION_STRING=mysql://user:pass@gateway01.prod.aws.tidbcloud.com:4000/test

# Agnes AI via ZenMux (get from: zenmux.ai console)
ZENMUX_API_KEY=

# Bright Data SERP API (get from: brightdata.com control panel)
BRIGHTDATA_API_KEY=
BRIGHTDATA_SERP_ZONE=

# Mem9 (self-hosted mnemo-server, provision key: curl -X POST localhost:8080/v1alpha1/mem9s)
MEM9_API_KEY=
MEM9_BASE_URL=http://localhost:8080

# User context (injected into AI prompts)
USER_ROLE=Engineering Manager
USER_TEAM_CONTEXT=
